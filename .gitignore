# Sentinel Shield — generated artifacts and local noise.
# Anchored to the repo root so the reference integration under
# examples/**/reports/ (with committed .gitkeep) is not ignored.
/reports/
*.log
# ...except committed test-fixture evidence excerpts (self-test depends on them).
!tests/fixtures/**/*.log
.DS_Store

# Baseline / scan caches that may appear in consuming projects.
.trivyignore.tmp
sbom.cdx.json
.phpstan.cache/
.php-cs-fixer.cache

# Local agent metadata (never commit)
.claude/
graphify-out/

# Local scan caches / runtime state (never commit)
.sentinel-shield/

# v1.4.0 sprint scratch (ledgers / working artifacts — never commit)
.sprint-v140/

# Isolated tool installs (scripts/lib/isolated-tools.sh) — commit composer.json + composer.lock, ignore vendor/.
tools/*/vendor/

# Never commit node_modules anywhere, incl. test fixtures.
tests/**/node_modules/
