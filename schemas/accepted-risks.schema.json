{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinel-shield/schemas/accepted-risks.schema.json",
  "title": "Sentinel Shield accepted risks",
  "description": "Explicit, owner-bound, expiring records that may suppress a SUPPRESSIBLE gate when status is approved and the record is unexpired. Consumed by scripts/enforce-gates.sh (v0.1.3+). Never suppresses secrets/expired_exceptions/missing_release_evidence.",
  "type": "object",
  "required": ["version", "risks"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "string" },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "gate", "owner", "severity", "reason", "expires_at", "status"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "gate": {
            "type": "string",
            "description": "Gate this record targets. Only 'unsafe_docker' and 'medium_vulnerabilities' are honored as suppressions in v0.1.3; others are ignored.",
            "enum": [
              "unsafe_docker",
              "medium_vulnerabilities",
              "critical_vulnerabilities",
              "high_vulnerabilities",
              "architecture_violations",
              "type_errors",
              "test_failures",
              "unsafe_github_actions",
              "missing_sbom"
            ]
          },
          "owner": { "type": "string", "minLength": 1 },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "reason": { "type": "string", "minLength": 1 },
          "mitigation": { "type": "string" },
          "expires_at": {
            "type": "string",
            "description": "ISO date (YYYY-MM-DD). A record only suppresses while expires_at >= today.",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "review_at": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "approved", "rejected", "expired"]
          },
          "approved_by": { "type": "string" }
        }
      }
    }
  }
}
