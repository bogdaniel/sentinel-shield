<?xml version="1.0"?>
<!--
  Sentinel Shield - Symfony Psalm baseline with taint analysis.

  Install (dev):   composer require vimeo/psalm psalm/plugin-symfony
  Taint analysis:  run psalm with the taint-analysis option (traces request input
                   to SQL/shell/HTML sinks; slower, run in security CI).
  Baseline legacy: run psalm with the set-baseline option to write psalm-baseline.xml

  errorLevel 4 is a migration start; lower toward 1 in strict mode.
  NOTE: XML comments cannot contain a double hyphen, so CLI flags are described in
  prose rather than shown verbatim.
-->
<psalm
    errorLevel="4"
    resolveFromConfigFile="true"
    findUnusedBaselineEntry="true"
    findUnusedCode="false"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
>
    <projectFiles>
        <directory name="src" />
        <ignoreFiles>
            <directory name="vendor" />
            <directory name="var" />
        </ignoreFiles>
    </projectFiles>

    <plugins>
        <pluginClass class="Psalm\SymfonyPsalmPlugin\Plugin">
            <containerXml>var/cache/dev/App_KernelDevDebugContainer.xml</containerXml>
        </pluginClass>
    </plugins>

    <issueHandlers>
        <TaintedSql errorLevel="error" />
        <TaintedShell errorLevel="error" />
        <TaintedHtml errorLevel="error" />
        <TaintedHeader errorLevel="error" />
        <TaintedInclude errorLevel="error" />
        <TaintedSystemSecret errorLevel="error" />

        <PropertyNotSetInConstructor errorLevel="suppress" />
        <MissingClosureReturnType errorLevel="suppress" />
    </issueHandlers>
</psalm>
