        }
      ],
      "executable": [
        "node_modules/.bin/eslint",
        "eslint"
      ],
      "runner": "scripts/runners/eslint-boundaries.sh",
      "report": "reports/raw/eslint-boundaries.json",
      "missing_behavior": "warn",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      },
      "config": {
        "path": "eslint.config.js",
        "classification": "project-owned"
      }
    },
    "js-architecture-tests": {
      "policy": "optional",
      "category": "architecture",
      "runner": "scripts/runners/js-architecture-tests.sh",
      "report": "reports/raw/js-architecture-tests.json",
      "missing_behavior": "info",
      "execution": {
        "pr": false,
        "main": true,
        "scheduled": false
      }
    },
    "test-change-evidence": {
      "policy": "recommended",
      "category": "testing-discipline",
      "runner": "scripts/runners/test-change-evidence.sh",
      "report": "reports/raw/test-change-evidence.json",
      "missing_behavior": "warn",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "cucumber-specs": {
      "policy": "optional",
      "category": "bdd",
      "packages": [
        {
          "name": "@cucumber/cucumber",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "node_modules/.bin/cucumber-js"
      ],
      "runner": "scripts/runners/cucumber-js.sh",
      "report": "reports/raw/cucumber-specs.json",
      "missing_behavior": "info",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "playwright-acceptance": {
