  "tool_notes": {
    "typescript": "policy:required applies when tsconfig.json is present; JS-only projects (no tsconfig.json): not-applicable. A JS-only project must NOT fail for absent TypeScript; a TS project MUST fail when the typecheck is unavailable.",
    "package-manager": "Detect npm/pnpm/yarn from the lockfile (package-lock.json -> npm, pnpm-lock.yaml -> pnpm, yarn.lock -> yarn); deps-install/npm-audit use that manager. NEVER switch the project's package manager.",
    "tests": "one-of jest|vitest; only gated when a test setup is configured. If neither is present and no tests are configured, the group is not-applicable.",
    "ci-linters": "actionlint and zizmor apply when .github/workflows/ exists; otherwise not-applicable (missing_behavior:warn so an absent linter never hard-fails)."
  }
}
