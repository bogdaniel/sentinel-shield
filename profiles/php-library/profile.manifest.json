      "missing_behavior": "warn",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "php-diff-coverage": {
      "policy": "recommended",
      "category": "coverage",
      "executable": [
        "vendor/bin/pest",
        "vendor/bin/phpunit"
      ],
      "runner": "scripts/runners/php-diff-coverage.sh",
