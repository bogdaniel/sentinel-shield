      ],
      "runner": "scripts/runners/phpmd-complexity.sh",
      "report": "reports/raw/php-complexity.json",
      "missing_behavior": "warn",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "php-duplication": {
      "policy": "recommended",
      "category": "duplication",
      "packages": [
        {
          "name": "sebastian/phpcpd",
          "scope": "dev",
