        }
      ],
      "executable": [
        "vendor/bin/phpcpd",
        "phpcpd"
      ],
      "runner": "scripts/runners/phpcpd.sh",
      "report": "reports/raw/php-duplication.json",
      "missing_behavior": "warn",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "php-mutation": {
      "policy": "optional",
      "category": "mutation",
      "packages": [
        {
          "name": "infection/infection",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/infection",
        "infection"
      ],
      "runner": "scripts/runners/infection.sh",
      "report": "reports/raw/php-mutation.json",
      "missing_behavior": "info",
      "execution": {
        "pr": false,
        "main": false,
        "scheduled": true
      }
    },
    "php-dead-code": {
      "policy": "optional",
      "category": "dead-code",
      "report": "reports/raw/php-dead-code.json",
      "missing_behavior": "info",
      "execution": {
        "pr": false,
        "main": false,
        "scheduled": true
      }
    },
    "focused-tests": {
      "policy": "recommended",
      "category": "test-hygiene",
      "runner": "scripts/runners/focused-tests.sh",
      "report": "reports/raw/focused-tests.json",
      "missing_behavior": "warn",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "debug-code": {
      "policy": "recommended",
      "category": "hygiene",
      "runner": "scripts/runners/debug-code.sh",
      "report": "reports/raw/debug-code.json",
      "missing_behavior": "warn",
