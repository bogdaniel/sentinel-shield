{
  "$schema": "../profile.manifest.schema.json",
  "profile": "php-library",
  "description": "Plain PHP library (no framework). PHPStan (generic, not Larastan) + composer audit + PHPUnit adapter. phpstan.neon/phpstan-baseline.neon are project-local and NEVER overwritten. No Docker/Laravel runner assumptions.",
  "stacks": [
    "php"
  ],
  "tool_policy_version": 2,
  "files": [
    {
      "source": "templates/profile.yaml",
      "target": ".sentinel-shield/profile.yaml",
      "mode": "create-if-missing"
    },
    {
      "source": "templates/accepted-risks.example.json",
      "target": ".sentinel-shield/accepted-risks.example.json",
      "mode": "create-if-missing"
    },
    {
      "source": "profiles/laravel/.semgrepignore",
      "target": ".semgrepignore",
      "mode": "create-if-missing"
    }
  ],
  "workflows": [
    {
      "source": "templates/workflows/sentinel-shield.yml",
      "target": ".github/workflows/sentinel-shield.yml",
      "mode": "overwrite-if-force"
    }
  ],
  "docs": [
    {
      "source": "templates/security-debt-register.md",
      "target": "docs/security/security-debt-register.md",
      "mode": "create-if-missing"
    }
  ],
  "never_touch": [
    ".sentinel-shield/accepted-risks.json",
    "phpstan-baseline.neon",
    "phpstan.neon"
  ],
  "required_scripts": [
    "scripts/adapters/phpunit-to-tests-json.php",
    "scripts/runners/php-syntax.sh",
    "scripts/build-security-summary.sh",
    "scripts/enforce-gates.sh"
  ],
  "recommended_pr_fast_tools": [
    "php-syntax",
    "phpstan",
    "composer-audit",
    "gitleaks",
    "semgrep",
    "tests",
    "test-change-evidence"
  ],
  "recommended_main_gate_tools": [
    "codeql",
    "osv-scanner",
    "trivy-fs",
    "syft",
    "grype",
    "dependency-check"
  ],
  "recommended_scheduled_tools": [
    "trufflehog",
    "scorecard",
    "dependency-check",
    "grype"
  ],
  "recommended_raw_reports": [
    "php-syntax.json",
    "phpstan.json",
    "tests.json",
    "composer-audit.json",
    "gitleaks.json",
    "semgrep.json",
    "php-coverage.json",
    "php-complexity.json",
    "php-duplication.json",
    "php-diff-coverage.json",
    "focused-tests.json",
    "debug-code.json",
    "source-size.json",
    "test-change-evidence.json"
  ],
  "tools": {
    "php-syntax": {
      "policy": "required",
      "category": "static-analysis",
      "executable": [
        "php"
      ],
      "runner": "scripts/runners/php-syntax.sh",
      "report": "reports/raw/php-syntax.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "phpstan": {
      "policy": "required",
      "category": "static-analysis",
      "packages": [
        {
          "name": "phpstan/phpstan",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/phpstan",
        "phpstan"
      ],
      "runner": "scripts/runners/phpstan.sh",
      "report": "reports/raw/phpstan.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      },
      "config": {
        "path": "phpstan.neon",
        "classification": "never-touch"
      }
    },
    "pest": {
      "policy": "one-of",
      "category": "tests",
      "packages": [
        {
          "name": "pestphp/pest",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/pest"
      ],
      "alternatives": [
        "phpunit"
      ],
      "report": "reports/raw/tests.json",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "phpunit": {
      "policy": "one-of",
      "category": "tests",
      "packages": [
        {
          "name": "phpunit/phpunit",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/phpunit"
      ],
      "alternatives": [
        "pest"
      ],
      "report": "reports/raw/tests.json",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "php-style": {
      "policy": "required",
      "category": "code-style",
      "packages": [
        {
          "name": "friendsofphp/php-cs-fixer",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/php-cs-fixer",
        "php-cs-fixer"
      ],
      "runner": "scripts/runners/php-style.sh",
      "report": "reports/raw/php-style.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "composer-audit": {
      "policy": "required",
      "category": "sca",
      "executable": [
        "composer"
      ],
      "report": "reports/raw/composer-audit.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "gitleaks": {
      "policy": "required",
      "category": "secrets",
      "executable": [
        "gitleaks"
      ],
      "report": "reports/raw/gitleaks.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "semgrep": {
      "policy": "required",
      "category": "static-analysis",
      "executable": [
        "semgrep"
      ],
      "report": "reports/raw/semgrep.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "codeql": {
      "policy": "required",
      "category": "static-analysis",
      "executable": [
        "codeql"
      ],
      "report": "reports/raw/codeql.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": false,
        "main": true,
        "scheduled": false
      }
    },
    "osv-scanner": {
      "policy": "required",
      "category": "sca",
      "executable": [
        "osv-scanner"
      ],
      "report": "reports/raw/osv-scanner.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": false,
        "main": true,
        "scheduled": false
      }
    },
    "syft": {
      "policy": "required",
      "category": "supply-chain",
      "executable": [
        "syft"
      ],
      "report": "reports/raw/syft.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": false,
        "main": true,
        "scheduled": false
      }
    },
    "grype": {
      "policy": "required",
      "category": "sca",
      "executable": [
        "grype"
      ],
      "report": "reports/raw/grype.json",
      "missing_behavior": "fail",
      "requires": [
        "syft"
      ],
      "execution": {
        "pr": false,
        "main": true,
        "scheduled": false
      }
    },
    "psalm": {
      "policy": "recommended",
      "category": "static-analysis",
      "packages": [
        {
          "name": "vimeo/psalm",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/psalm",
        "psalm"
      ],
      "runner": "scripts/runners/psalm.sh",
      "report": "reports/raw/psalm.json",
      "missing_behavior": "warn",
      "execution": {
        "pr": false,
        "main": true,
        "scheduled": false
      },
      "config": {
        "path": "psalm.xml",
        "classification": "never-touch"
      }
    },
    "deptrac": {
      "policy": "recommended",
      "category": "architecture",
      "packages": [
        {
          "name": "deptrac/deptrac",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/deptrac",
        "deptrac"
      ],
      "runner": "scripts/runners/deptrac.sh",
      "report": "reports/raw/deptrac.json",
      "missing_behavior": "warn",
      "execution": {
        "pr": false,
        "main": true,
        "scheduled": false
      },
      "config": {
        "path": "deptrac.yaml",
        "classification": "never-touch"
      }
    },
    "rector": {
      "policy": "recommended",
      "category": "static-analysis",
      "packages": [
        {
          "name": "rector/rector",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/rector",
        "rector"
      ],
      "runner": "scripts/runners/rector.sh",
      "report": "reports/raw/rector.json",
      "missing_behavior": "warn",
      "execution": {
        "pr": false,
        "main": true,
        "scheduled": false
      },
      "config": {
        "path": "rector.php",
        "classification": "never-touch"
      }
    },
    "php-tests": {
      "policy": "one-of",
      "category": "tests",
      "alternatives": [
        "pest",
        "phpunit"
      ],
      "report": "reports/raw/tests.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "php-coverage": {
      "policy": "recommended",
