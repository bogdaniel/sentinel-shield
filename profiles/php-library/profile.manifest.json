      "runner": "scripts/runners/test-change-evidence.sh",
      "report": "reports/raw/test-change-evidence.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "behat": {
      "policy": "optional",
      "category": "bdd",
      "packages": [
        {
          "name": "behat/behat",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/behat",
        "behat"
      ],
      "runner": "scripts/runners/behat.sh",
      "report": "reports/raw/behavior-specs.json",
      "missing_behavior": "info",
