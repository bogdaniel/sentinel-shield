    },
    "php-arkitect": {
      "policy": "optional",
      "category": "architecture",
      "packages": [
        {
          "name": "phparkitect/phparkitect",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/phparkitect",
        "phparkitect"
      ],
      "runner": "scripts/runners/php-arkitect.sh",
      "report": "reports/raw/php-arkitect.json",
      "missing_behavior": "info",
      "execution": {
