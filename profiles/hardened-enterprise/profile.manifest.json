{
  "$schema": "../profile.manifest.schema.json",
  "profile": "hardened-enterprise",
  "description": "First-class OPT-IN hardened enterprise overlay. Installs the standard managed files plus the digest-pinned/SHA-pinned hardened reference snippet and enterprise hardening guidance. Defaults are unchanged: this profile is selected explicitly with --profile hardened-enterprise. Pin scanner image digests + GitHub Action SHAs (see the shipped snippet) before production; keep permissions minimal, add timeout-minutes/concurrency/retention; NVD key is consumer-provided and never committed.",
  "stacks": ["enterprise"],
  "extends": ["laravel", "node", "docker"],
  "files": [
    { "source": "templates/profile.yaml", "target": ".sentinel-shield/profile.yaml", "mode": "create-if-missing" },
    { "source": "templates/accepted-risks.example.json", "target": ".sentinel-shield/accepted-risks.example.json", "mode": "create-if-missing" },
    { "source": "examples/hardened/sentinel-shield-hardened.snippet.yml", "target": ".sentinel-shield/hardened/sentinel-shield-hardened.snippet.yml", "mode": "create-if-missing" }
  ],
  "workflows": [
    { "source": "templates/workflows/sentinel-shield.yml", "target": ".github/workflows/sentinel-shield.yml", "mode": "overwrite-if-force" }
  ],
  "docs": [
    { "source": "templates/security-debt-register.md", "target": "docs/security/security-debt-register.md", "mode": "create-if-missing" }
  ],
  "never_touch": [".sentinel-shield/accepted-risks.json"],
  "required_scripts": ["scripts/build-security-summary.sh", "scripts/enforce-gates.sh"],
  "recommended_pr_fast_tools": ["gitleaks", "semgrep", "composer-audit", "npm-audit", "php-syntax", "phpstan", "tests"],
  "recommended_main_gate_tools": ["codeql", "osv-scanner", "trivy-fs", "syft", "grype", "dependency-check", "deptrac"],
  "recommended_scheduled_tools": ["trufflehog", "scorecard", "dependency-check", "dockle"],
  "recommended_raw_reports": ["gitleaks.json", "semgrep.json", "composer-audit.json", "trivy.json", "dependency-check.json"]
}
