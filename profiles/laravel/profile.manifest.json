    "trufflehog": {
      "policy": "optional",
      "category": "secrets",
      "report": "reports/raw/trufflehog.json",
      "missing_behavior": "info",
      "execution": {
        "pr": false,
        "main": false,
        "scheduled": true
      }
    },
    "zap": {
