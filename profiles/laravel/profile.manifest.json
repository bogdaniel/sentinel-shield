{
  "$schema": "../profile.manifest.schema.json",
  "profile": "laravel",
  "description": "Laravel/PHP stack. Project config (PHPStan/Larastan, Deptrac, Pint) + .semgrepignore. PHPStan runs via the upstream Laravel runner; phpstan.neon/phpstan-baseline.neon are project-local and NEVER overwritten.",
  "stacks": [
    "laravel"
  ],
  "tool_policy_version": 2,
  "files": [
    {
      "source": "templates/profile.yaml",
      "target": ".sentinel-shield/profile.yaml",
      "mode": "create-if-missing"
    },
    {
      "source": "templates/accepted-risks.example.json",
      "target": ".sentinel-shield/accepted-risks.example.json",
      "mode": "create-if-missing"
    },
    {
      "source": "profiles/laravel/.semgrepignore",
      "target": ".semgrepignore",
      "mode": "create-if-missing"
    },
    {
      "source": "profiles/laravel/phpstan.neon",
      "target": "phpstan.neon",
      "mode": "manual"
    }
  ],
  "workflows": [
    {
      "source": "templates/workflows/sentinel-shield.yml",
      "target": ".github/workflows/sentinel-shield.yml",
      "mode": "overwrite-if-force"
    }
  ],
  "docs": [
    {
      "source": "templates/security-debt-register.md",
      "target": "docs/security/security-debt-register.md",
      "mode": "create-if-missing"
    }
  ],
  "never_touch": [
    ".sentinel-shield/accepted-risks.json",
    "phpstan-baseline.neon",
    "phpstan.neon"
  ],
  "required_scripts": [
    "scripts/runners/laravel-phpstan.sh",
    "scripts/adapters/phpunit-to-tests-json.php",
    "scripts/build-security-summary.sh",
    "scripts/enforce-gates.sh"
  ],
  "recommended_pr_fast_tools": [
    "php-syntax",
    "phpstan",
    "composer-audit",
    "gitleaks",
    "semgrep",
    "tests"
  ],
  "recommended_main_gate_tools": [
    "codeql",
    "osv-scanner",
    "trivy-fs",
    "syft",
    "grype",
    "deptrac",
    "dependency-check"
  ],
  "recommended_scheduled_tools": [
    "trufflehog",
    "scorecard",
    "dependency-check",
    "grype-fs"
  ],
  "recommended_raw_reports": [
    "phpstan.json",
    "tests.json",
    "composer-audit.json",
    "gitleaks.json",
    "semgrep.json",
    "deptrac.json"
  ],
  "tools": {
    "php-syntax": {
      "policy": "required",
      "category": "static-analysis",
      "executable": [
        "php"
      ],
      "runner": "scripts/runners/php-syntax.sh",
      "report": "reports/raw/php-syntax.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "phpstan": {
      "policy": "required",
      "category": "static-analysis",
      "packages": [
        {
          "name": "phpstan/phpstan",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/phpstan",
        "phpstan"
      ],
      "runner": "scripts/runners/laravel-phpstan.sh",
      "report": "reports/raw/phpstan.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      },
      "config": {
        "path": "phpstan.neon",
        "classification": "never-touch"
      }
    },
    "larastan": {
      "policy": "required",
      "category": "static-analysis",
      "packages": [
        {
          "name": "larastan/larastan",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/phpstan",
        "phpstan"
      ],
      "runner": "scripts/runners/larastan.sh",
      "report": "reports/raw/larastan.json",
      "missing_behavior": "fail",
      "requires": [
        "phpstan"
      ],
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      },
      "config": {
        "path": "phpstan.neon",
        "classification": "never-touch"
      }
    },
    "pint": {
      "policy": "required",
      "category": "style",
      "packages": [
        {
          "name": "laravel/pint",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/pint",
        "pint"
      ],
      "runner": "scripts/runners/pint.sh",
      "report": "reports/raw/pint.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      },
      "config": {
        "path": "pint.json",
        "classification": "create-if-missing"
      }
    },
    "pest": {
      "policy": "one-of",
      "category": "tests",
      "packages": [
        {
          "name": "pestphp/pest",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/pest"
      ],
      "runner": "scripts/runners/pest.sh",
      "alternatives": [
        "phpunit"
      ],
      "report": "reports/raw/tests.json",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "phpunit": {
      "policy": "one-of",
      "category": "tests",
      "packages": [
        {
          "name": "phpunit/phpunit",
          "scope": "dev",
          "compatibility": "auto"
        }
      ],
      "executable": [
        "vendor/bin/phpunit"
      ],
      "runner": "scripts/runners/phpunit.sh",
      "alternatives": [
        "pest"
      ],
      "report": "reports/raw/tests.json",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "composer-audit": {
      "policy": "required",
      "category": "sca",
      "executable": [
        "composer"
      ],
      "report": "reports/raw/composer-audit.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "gitleaks": {
      "policy": "required",
      "category": "secrets",
      "report": "reports/raw/gitleaks.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "semgrep": {
      "policy": "required",
      "category": "static-analysis",
      "report": "reports/raw/semgrep.json",
      "missing_behavior": "fail",
      "execution": {
        "pr": true,
        "main": true,
        "scheduled": false
      }
    },
    "actionlint": {
      "policy": "required",
