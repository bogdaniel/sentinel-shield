{
    "name": "sentinel-shield/php-library-consumer-fixture",
    "description": "Framework-agnostic PHP library consumer fixture for Sentinel Shield real-consumer validation. This is a plain Composer package (PSR-4), NOT a Laravel or Symfony application.",
    "type": "library",
    "keywords": ["sentinel-shield", "consumer-fixture", "php-library"],
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "laravel/pint": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --no-progress",
        "style": "pint --test"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
