{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": { "driver": { "name": "CodeQL" } },
      "results": [
        {
          "ruleId": "js/sql-injection",
          "level": "error",
          "message": { "text": "This query depends on a user-provided value." },
          "locations": [{ "physicalLocation": { "artifactLocation": { "uri": "src/db.js" } } }]
        },
        {
          "ruleId": "js/xss",
          "level": "error",
          "message": { "text": "Cross-site scripting vulnerability." },
          "locations": [{ "physicalLocation": { "artifactLocation": { "uri": "src/view.js" } } }]
        },
        {
          "ruleId": "js/unused-local-variable",
          "level": "warning",
          "message": { "text": "Unused variable." },
          "locations": [{ "physicalLocation": { "artifactLocation": { "uri": "src/util.js" } } }]
        }
      ]
    }
  ]
}
